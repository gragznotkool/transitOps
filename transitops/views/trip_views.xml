<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_transitops_trip_tree" model="ir.ui.view">
        <field name="name">transitops.trip.tree</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <list string="Trips" decoration-info="trip_status == 'dispatched'" decoration-warning="trip_status == 'started'" decoration-success="trip_status == 'completed'" decoration-muted="trip_status in ('draft','archived')">
                <field name="trip_number" decoration-bf="1"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="distance" sum="Total Distance"/>
                <field name="cargo_weight"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'" decoration-info="priority == 'medium'"/>
                <field name="trip_status" widget="badge" decoration-info="trip_status == 'dispatched'" decoration-warning="trip_status == 'started'" decoration-success="trip_status == 'completed'" decoration-muted="trip_status == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transitops_trip_form" model="ir.ui.view">
        <field name="name">transitops.trip.form</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <form string="Trip Sheet">
                <header>
                    <button name="action_validate" string="Approve / Validate" type="object" class="oe_highlight" invisible="trip_status != 'draft'"/>
                    <button name="action_dispatch" string="Dispatch Fleet" type="object" class="oe_highlight" invisible="trip_status != 'validated'"/>
                    <button name="action_start" string="Start Transit" type="object" class="oe_highlight" invisible="trip_status != 'dispatched'"/>
                    <button name="action_complete" string="Complete Delivery" type="object" class="oe_highlight" invisible="trip_status != 'started'"/>
                    <button name="action_archive" string="Archive Records" type="object" invisible="trip_status != 'completed'"/>
                    <field name="trip_status" widget="statusbar" statusbar_visible="draft,validated,dispatched,started,completed,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="trip_number" class="oe_edit_only" string="Trip ID"/>
                        <h1>
                            <field name="trip_number" readonly="1"/>
                        </h1>
                        <div class="o_row" style="margin-top: 4px; display: flex; gap: 10px; align-items: center;">
                            <field name="source" placeholder="Origin Address (e.g. Dallas Depot)"/>
                            <span class="fa fa-arrow-right" style="color: #64748b;"/>
                            <field name="destination" placeholder="Destination Address (e.g. Austin Gateway)"/>
                        </div>
                    </div>

                    <group style="margin-top: 20px;">
                        <group name="logistics" string="Core Dispatch Details">
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="priority"/>
                            <field name="weather"/>
                        </group>
                        <group name="timings" string="Schedule &amp; Timings">
                            <field name="eta"/>
                            <field name="start_time" readonly="1"/>
                            <field name="end_time" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="cargo_telemetry" string="Cargo &amp; Telemetry">
                            <group>
                                <group name="cargo" string="Cargo Attributes">
                                    <field name="cargo_weight"/>
                                    <field name="cargo_type"/>
                                </group>
                                <group name="route" string="Distance Parameters">
                                    <field name="distance"/>
                                </group>
                            </group>
                        </page>
                        <page name="financials" string="Telemetry &amp; Cost Control">
                            <group>
                                <group name="est" string="Pre-Calculated Estimates">
                                    <field name="estimated_fuel" readonly="1"/>
                                    <field name="estimated_cost" widget="monetary" readonly="1"/>
                                </group>
                                <group name="act" string="Real-Time Final Cost">
                                    <field name="actual_fuel"/>
                                    <field name="actual_cost" widget="monetary"/>
                                    <field name="revenue" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page name="audit_trail" string="Trip Timeline History">
                            <field name="timeline_ids" readonly="1">
                                <list string="Timeline Events">
                                    <field name="timestamp"/>
                                    <field name="user_id"/>
                                    <field name="action_status"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_transitops_trip_graph" model="ir.ui.view">
        <field name="name">transitops.trip.graph</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <graph string="Trips Analytics" type="bar">
                <field name="destination"/>
                <field name="revenue" type="measure"/>
                <field name="distance" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_transitops_trip_pivot" model="ir.ui.view">
        <field name="name">transitops.trip.pivot</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <pivot string="Trips Aggregation">
                <field name="source" type="row"/>
                <field name="destination" type="row"/>
                <field name="trip_status" type="col"/>
                <field name="revenue" type="measure"/>
                <field name="actual_cost" type="measure"/>
                <field name="distance" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_trip" model="ir.actions.act_window">
        <field name="name">Logistics Trips</field>
        <field name="res_model">transitops.trip</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Dispatch your first cargo trip!
            </p>
            <p>
                Manage routing, driver assignments, vehicle payload checks, status synchronizations, and trip telemetry audits.
            </p>
        </field>
    </record>
</odoo>
