<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_transitops_driver_tree" model="ir.ui.view">
        <field name="name">transitops.driver.tree</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <list string="Drivers" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-danger="status == 'suspended'" decoration-muted="status == 'inactive'">
                <field name="name" decoration-bf="1"/>
                <field name="license_category"/>
                <field name="license_expiry"/>
                <field name="phone"/>
                <field name="experience"/>
                <field name="safety_score" widget="progressbar"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-danger="status == 'suspended'" decoration-muted="status == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_transitops_driver_kanban" model="ir.ui.view">
        <field name="name">transitops.driver.kanban</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="photo"/>
                <field name="license_category"/>
                <field name="safety_score"/>
                <field name="status"/>
                <field name="assigned_vehicle_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record" style="border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); border-left: 5px solid; padding: 12px; margin-bottom: 8px;"
                             t-attf-style="border-left-color: #{record.status.raw_value == 'available' ? '#10b981' : record.status.raw_value == 'on_trip' ? '#3b82f6' : record.status.raw_value == 'suspended' ? '#ef4444' : '#6b7280'}">
                            <div class="o_kanban_image" style="width: 50px; height: 50px; border-radius: 50%; overflow: hidden; margin-right: 12px; float: left;">
                                <t t-if="record.photo.raw_value">
                                    <field name="photo" widget="image" style="width: 100%; height: 100%; object-fit: cover;"/>
                                </t>
                                <t t-else="">
                                    <img t-att-src='_s + "/base/static/img/avatar_grey.png"' alt="Driver" style="width: 100%; height: 100%; object-fit: cover;"/>
                                </t>
                            </div>
                            <div class="oe_kanban_details" style="display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <strong class="o_kanban_record_title" style="font-size: 14px; color: #1e293b;">
                                        <field name="name"/>
                                    </strong>
                                    <div style="font-size: 11px; color: #64748b; margin-top: 2px;">
                                        Lic: <field name="license_category"/>
                                    </div>
                                    <div style="font-size: 11px; color: #475569; margin-top: 4px;">
                                        Vehicle: <field name="assigned_vehicle_id"/>
                                    </div>
                                </div>
                                <div style="margin-top: 10px; display: flex; align-items: center; justify-content: space-between;">
                                    <span style="font-size: 11px; font-weight: 600;" t-attf-class="text-#{record.safety_score.raw_value &gt;= 80 ? 'success' : record.safety_score.raw_value &gt;= 65 ? 'warning' : 'danger'}">
                                        Safety: <t t-esc="record.safety_score.value"/>%
                                    </span>
                                    <span t-attf-class="badge rounded-pill bg-#{record.status.raw_value == 'available' ? 'success' : record.status.raw_value == 'on_trip' ? 'primary' : record.status.raw_value == 'suspended' ? 'danger' : 'secondary'}" style="font-size: 10px; padding: 4px 8px;">
                                        <field name="status"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transitops_driver_form" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form string="Driver Profile">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,suspended,inactive" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar" options="{'zoom': true, 'preview_image': 'photo'}"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Driver Full Name"/>
                        </h1>
                        <div class="o_row" style="margin-top: 4px;">
                            <span class="fa fa-envelope" style="color: #64748b; margin-right: 4px;"/>
                            <field name="email" placeholder="email@address.com"/>
                            <span class="fa fa-phone" style="color: #64748b; margin-left: 10px; margin-right: 4px;"/>
                            <field name="phone" placeholder="e.g. +1 555 1234"/>
                        </div>
                    </div>

                    <group style="margin-top: 20px;">
                        <group name="licensing" string="Licensing Details">
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry"/>
                            <field name="emergency_contact"/>
                        </group>
                        <group name="perf" string="Performance Metrics">
                            <field name="assigned_vehicle_id" domain="[('current_status', '=', 'available')]"/>
                            <field name="experience"/>
                            <field name="safety_score" widget="integer"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="statistics" string="Performance Stats">
                            <group>
                                <group string="Trip Aggregates">
                                    <field name="trips_completed"/>
                                    <field name="total_distance_driven"/>
                                </group>
                                <group string="Efficiencies &amp; Reliability">
                                    <field name="average_fuel_efficiency" string="Avg Fuel Efficiency (km/L)"/>
                                    <field name="average_delay" string="Avg Delay (hours)"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transitops.driver</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a logistics driver!
            </p>
            <p>
                Keep track of driver licenses, emergency contacts, safety ratings, fuel efficiency, and dispatch schedules.
            </p>
        </field>
    </record>
</odoo>
