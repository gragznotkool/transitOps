<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_transitops" model="ir.module.category">
            <field name="name">TransitOps Fleet Management</field>
            <field name="description">Access levels for TransitOps logistics application.</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_transitops_user" model="res.groups">
            <field name="name">Dispatcher / User</field>
            <field name="category_id" ref="module_category_transitops"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Standard dispatchers who view dashboards, manage trips, and log fuel/expenses.</field>
        </record>

        <record id="group_transitops_manager" model="res.groups">
            <field name="name">Operations Manager</field>
            <field name="category_id" ref="module_category_transitops"/>
            <field name="implied_ids" eval="[(4, ref('group_transitops_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Operations managers who can configure vehicles, set up drivers, and review operational audits.</field>
        </record>
    </data>
</odoo>
